<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.patrickkelker.ipod-autoconvert</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/patrickkelker/Library/Application Support/ipod-autoconvert/ipod_autorun_on_mount.sh</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>StartOnMount</key>
  <true/>

  <key>WatchPaths</key>
  <array>
    <string>/Volumes</string>
  </array>

  <key>StandardOutPath</key>
  <string>/tmp/com.patrickkelker.ipod-autoconvert.out</string>

  <key>StandardErrorPath</key>
  <string>/tmp/com.patrickkelker.ipod-autoconvert.err</string>
</dict>
</plist>
